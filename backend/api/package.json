{
  "name": "@scrubsafe/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "lint": "eslint src",
    "check": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 execute scrubsafe --local --file=src/db/schema.sql",
    "db:migrate:remote": "wrangler d1 execute scrubsafe --file=src/db/schema.sql"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "eslint": "^9.18.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "wrangler": "^3.99.0"
  }
}
